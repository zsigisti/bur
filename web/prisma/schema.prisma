// BUR data model — PostgreSQL via Prisma (self-hosted on .79).
// Role/status columns are validated strings (see src/lib/types.ts). We keep the
// child->User relations as NoAction and let Package own the cascade, so user
// deletion stays an explicit admin action.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  emailVerified DateTime?
  // "AUTHOR" | "MAINTAINER" | "CONTRIBUTOR"
  globalRole    String    @default("CONTRIBUTOR")
  approvedCount Int       @default(0)
  trusted       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  packagesOwned        Package[]             @relation("PackageOwner")
  recipesSubmitted     Recipe[]              @relation("RecipeSubmitter")
  recipesReviewed      Recipe[]              @relation("RecipeReviewer")
  packageRoles         PackageRole[]
  contributionRequests ContributionRequest[] @relation("RequestUser")
  sessions             Session[]
  twoFactorTokens      TwoFactorToken[]
  loginEvents          LoginEvent[]
  auditLogs            AuditLog[]            @relation("AuditActor")

  @@index([globalRole])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  ip        String?
  userAgent String?  @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TwoFactorToken {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  // "LOGIN_2FA" | "EMAIL_VERIFY" | "PASSWORD_RESET"
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
}

model Package {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.VarChar(1024)
  homepage    String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner                User                  @relation("PackageOwner", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recipes              Recipe[]
  roles                PackageRole[]
  contributionRequests ContributionRequest[]

  @@index([ownerId])
}

model Recipe {
  id              String    @id @default(cuid())
  packageId       String
  version         String
  release         Int       @default(1)
  summary         String?   @db.VarChar(1024)
  bpmToml         String    @db.Text
  // "DRAFT" | "PENDING" | "APPROVED" | "REJECTED" | "PUBLISHED"
  status          String    @default("PENDING")
  builtLocally    Boolean   @default(false)
  artifactSha256  String?
  artifactSize    Int?
  publishedRepo   String?
  publishedAt     DateTime?
  rejectionReason String?   @db.VarChar(1024)
  submittedById   String
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  package     Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  submittedBy User    @relation("RecipeSubmitter", fields: [submittedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewedBy  User?   @relation("RecipeReviewer", fields: [reviewedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([packageId])
  @@index([status])
  @@index([submittedById])
}

model PackageRole {
  id        String   @id @default(cuid())
  packageId String
  userId    String
  // "OWNER" | "CONTRIBUTOR"
  role      String
  grantedBy String?
  grantedAt DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([packageId, userId])
  @@index([userId])
}

model ContributionRequest {
  id          String    @id @default(cuid())
  packageId   String
  userId      String
  message     String?   @db.VarChar(1024)
  // "PENDING" | "APPROVED" | "REJECTED"
  status      String    @default("PENDING")
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user    User    @relation("RequestUser", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([packageId, userId])
  @@index([status])
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?  @db.VarChar(512)
  success   Boolean
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   String?  @db.Text
  ip         String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([action])
  @@index([actorId])
}
