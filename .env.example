# Copy to web/.env and fill in. NEVER commit the real file.

# Azure SQL (SQL Server). Format for Prisma sqlserver provider:
# sqlserver://<server>.database.windows.net:1433;database=<db>;user=<user>;password=<pw>;encrypt=true;trustServerCertificate=false
DATABASE_URL="sqlserver://REPLACE.database.windows.net:1433;database=bur;user=buradmin;password=REPLACE;encrypt=true"

# Resend (email 2FA / verification)
RESEND_API_KEY="re_REPLACE"
MAIL_FROM="BUR <no-reply@bur.mmzsigmond.me>"

# App
NODE_ENV="production"
PUBLIC_ORIGIN="https://bur.mmzsigmond.me"

# Community mirror the site publishes approved .bpm to
COMMUNITY_REPO_HOST="repo1.mmzsigmond.me"
