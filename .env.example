# Copy to web/.env and fill in. NEVER commit the real file.

# PostgreSQL (Prisma) — local Postgres on the app host.
DATABASE_URL="postgresql://bur:REPLACE@localhost:5432/bur?schema=public"

# Resend (email 2FA / verification)
RESEND_API_KEY="re_REPLACE"
MAIL_FROM="BUR <no-reply@mail.blueberrylinux.org>"

# App
NODE_ENV="production"
PUBLIC_ORIGIN="https://bur.blueberrylinux.org"
# Set to "false" only for local HTTP dev (Secure cookies require HTTPS).
COOKIE_SECURE="true"

# Community mirror the site publishes approved .bpm to
COMMUNITY_REPO_HOST="repo1.blueberrylinux.org"
